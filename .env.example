# Application
APP_NAME=AI Career Planning Agent
APP_ENV=development
APP_DEBUG=false
LOG_LEVEL=INFO

# Job profile LLM extraction
# Use "heuristic" for local rule-based extraction, or configure a remote provider when needed.
JOB_PROFILE_LLM_PROVIDER=heuristic
JOB_PROFILE_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
JOB_PROFILE_LLM_API_KEY=your-api-key-here
JOB_PROFILE_LLM_MODEL=glm-4.7-flash
JOB_PROFILE_LLM_TIMEOUT_SECONDS=30
JOB_PROFILE_BATCH_LIMIT=50
JOB_PROFILE_EXTRACTOR_VERSION=v1

# Career report LLM generation
# Leave empty to reuse the job profile LLM settings or fall back to heuristic behavior.
REPORTING_LLM_PROVIDER=
REPORTING_LLM_BASE_URL=
REPORTING_LLM_API_KEY=
REPORTING_LLM_MODEL=
REPORTING_LLM_TIMEOUT_SECONDS=30

# Xiaoya assistant
# Leave empty to reuse reporting/job profile LLM settings.
ASSISTANT_LLM_PROVIDER=
ASSISTANT_LLM_BASE_URL=
ASSISTANT_LLM_API_KEY=
ASSISTANT_LLM_MODEL=
ASSISTANT_LLM_TIMEOUT_SECONDS=30

# Service ports and URLs
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:8000

# PostgreSQL
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=career_planning
POSTGRES_USER=career_planning
POSTGRES_PASSWORD=career_planning

# Startup checks
SKIP_DB_CHECK=false
DEMO_AUTO_SEED_JOB_PROFILES=true
DEMO_JOB_SEED_PATH=/app/data/seeds/job_postings_sample.csv
